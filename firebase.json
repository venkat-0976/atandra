{
  "hosting": {
    "public": "dist",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/index.php/ups",
        "destination": "/protect/ups",
        "type": 301
      },
      {
        "source": "/index.php/power-quality-analysers",
        "destination": "/measure/power-quality-analyzers",
        "type": 301
      },
      {
        "source": "/index.php/thermal-imager",
        "destination": "/measure/thermal-imagers",
        "type": 301
      },
      {
        "source": "/index.php/energy-management-system-on-premise",
        "destination": "/conserve/on-premise-systems",
        "type": 301
      },
      {
        "source": "/index.php/events",
        "destination": "/about/events",
        "type": 301
      },
      {
        "source": "/index.php/contact-us",
        "destination": "/contact/sales",
        "type": 301
      },
      {
        "source": "/index.php/careers",
        "destination": "/about/careers",
        "type": 301
      },
      {
        "source": "/index.html",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/measure",
        "destination": "/measure/power-quality-analyzers",
        "type": 301
      },
      {
        "source": "/protect",
        "destination": "/protect/ups",
        "type": 301
      },
      {
        "source": "/conserve",
        "destination": "/conserve/on-premise-systems",
        "type": 301
      },
      {
        "source": "/contact",
        "destination": "/contact/sales",
        "type": 301
      },
      {
        "source": "/about",
        "destination": "/about/company",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/wp-admin/**",
        "destination": "/404.html"
      },
      {
        "source": "/wp-content/**",
        "destination": "/404.html"
      },
      {
        "source": "/wp-includes/**",
        "destination": "/404.html"
      },
      {
        "source": "**/*.pdf",
        "destination": "/404.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/javascript; charset=utf-8"
          },
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "**/*.css",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/css; charset=utf-8"
          },
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|webp|svg|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "**/*.pdf",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          }
        ]
      }
    ]
  }
}